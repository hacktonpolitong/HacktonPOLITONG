# PilotOps AI default demo works without environment variables.

# Optional: force deterministic local engine even if OpenRouter keys exist.
# Useful for fixture evals, demo rehearsal, and stable judge testing.
PILOTOPS_FORCE_LOCAL_ENGINE=0

# Optional live AI mode through OpenRouter.
# Keep real keys only in .env.local or Vercel environment variables.
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_API_KEY=
OPENROUTER_MODEL=deepseek/deepseek-v4-flash:free
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=PilotOps AI
